{
  "compilerOptions": {
    /* Output structure */
    "rootDir": ".",
    "outDir": "dist",

    /* Language and environment */
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",

    /* Interoperability */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,

    /* Type checking */
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Node/Amplify specific */
    "types": ["node"],

    /* Project setup */
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src", "amplify", "amplify.d.ts"],
  "exclude": ["node_modules"]
}
